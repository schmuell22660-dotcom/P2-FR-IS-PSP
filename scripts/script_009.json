  {
    "id": 17,
    "offset": 278402,
    "slot_size": 228,
    "data_size": 224,
    "nom_orig": "Maya",
    "texte_orig": "You[SP]three[SP]are[SP]chasing[SP]Joker[SP]himself,\nright?[SP]If[SP]we[SP]could[SP]catch[SP]him,[SP]that[SP]would\nbe[SP]one[SP]hell[SP]of[SP]a[SP]scoop!",
