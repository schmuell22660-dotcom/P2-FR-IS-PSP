  {
    "id": 15,
    "offset": 278060,
    "slot_size": 210,
    "data_size": 206,
    "nom_orig": "Maya",
    "texte_orig": "Well,[SP]we[SP]can[SP]save[SP]your[SP]origin[SP]stories\nfor[SP]later.[SP]Let's[SP]focus[SP]on[SP]where[SP]we\nshould[SP]go[SP]from[SP]here!",
