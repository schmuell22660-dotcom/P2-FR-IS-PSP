  {
    "id": 16,
    "offset": 278270,
    "slot_size": 132,
    "data_size": 128,
    "nom_orig": "Ginko",
    "texte_orig": "Haime!?[SP]Seriously!?[SP]You're[SP]gonna[SP]come\nalong[SP]with[SP]us?",
