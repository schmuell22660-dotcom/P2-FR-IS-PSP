  {
    "id": 4,
    "offset": 276444,
    "slot_size": 156,
    "data_size": 152,
    "nom_orig": "Maya",
    "texte_orig": "How[SP]weird...[1205][0014][SP]I[SP]felt[SP]it,[SP]too.[SP]What[SP]was\nthat[SP]wave[SP]of[SP]nostalgia...?",
