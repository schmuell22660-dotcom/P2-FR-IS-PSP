  {
    "id": 27,
    "offset": 280524,
    "slot_size": 158,
    "data_size": 154,
    "nom_orig": "Maya",
    "texte_orig": "If[SP]I[SP]remember[SP]right,[SP]Sevens'[SP]emblem[SP]is\nbased[SP]on[SP]the[SP]Pleiades,[SP]yeah?",
    "nom_fr": "Maya",
    "texte_fr": "L'emblème des Sevens est basé\nsur les Pléiades, c'est ça ?"
