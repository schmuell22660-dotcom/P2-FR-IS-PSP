  {
    "id": 6,
    "offset": 276832,
    "slot_size": 222,
    "data_size": 218,
    "nom_orig": "Maya",
    "texte_orig": "You[SP]mean[SP]you[SP]three[SP]have[SP]the[SP]same[SP]powers\nI[SP]do?[SP]Persona,[SP]huh...[SP]So[SP]it's[SP]not[SP]just\nmy[SP]guardian[SP]angel...",
