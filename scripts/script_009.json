  {
    "id": 7,
    "offset": 277054,
    "slot_size": 140,
    "data_size": 136,
    "nom_orig": "Maya",
    "texte_orig": "And[SP]wow,[SP]I[SP]can't[SP]believe[SP]you're[SP]a\nPersona-user[SP]too,[SP]Yukki!",
    "nom_fr": "Maya",
    "texte_fr": "Et toi aussi t'es une\nutilisatrice de Persona, Yukki !"
