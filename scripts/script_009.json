  {
    "id": 42,
    "offset": 283644,
    "slot_size": 198,
    "data_size": 194,
    "nom_orig": "Yukino",
    "texte_orig": "My[SP]pals[SP]and[SP]me[SP]threw[SP]down[SP]with[SP]demons\nand[SP]other[SP]Persona-users[SP]and[SP]took[SP]back\nour[SP]town.",
