    "slot_size": 192,
    "data_size": 188,
    "nom_orig": "Joker",
    "texte_orig": "I[SP]am[SP]Joker...[1205][001E][SP]The[SP]final[SP]trump[SP]card[SP]drawn\nby[SP]those[SP]anguished[SP]over[SP]their[SP]dreams...",
    "nom_fr": "Joker",
