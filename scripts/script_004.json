  {
    "id": 5,
    "offset": 367406,
    "slot_size": 206,
    "data_size": 202,
    "nom_orig": "Eikichi",
    "texte_orig": "The[SP]thing[SP]where[SP]you[SP]call[SP]your[SP]own[SP]cell\nand[SP]it[SP]shows[SP]up?[1205][001E][SP]Why[SP]would[SP]I[SP]want[SP]to\ntry[SP]that?",
