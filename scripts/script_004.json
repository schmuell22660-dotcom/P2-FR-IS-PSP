    "id": 7,
    "offset": 367856,
    "slot_size": 146,
    "data_size": 142,
    "nom_orig": "Eikichi",
    "texte_orig": "I'll[SP]pass.[1205][001E][SP]There's[SP]no[SP]way[SP]all[SP]that\ncould[SP]be[SP]possible...",
