  {
    "id": 4,
    "offset": 367288,
    "slot_size": 118,
    "data_size": 114,
    "nom_orig": "Lisa",
    "texte_orig": "Hey,[SP]I[SP]know...[1205][001E][SP]You[SP]wanna[SP]try[SP]the\nJoker[SP]Game?",
