    "offset": 370826,
    "slot_size": 136,
    "data_size": 132,
    "nom_orig": "Joker",
    "texte_orig": "But[SP]enough[SP]chitchat.[SP]I[SP]have[SP]other[SP]business\nwith[SP]you...",
