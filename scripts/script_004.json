    "id": 8,
    "offset": 368002,
    "slot_size": 162,
    "data_size": 158,
    "nom_orig": "Lisa",
    "texte_orig": "That's[SP]why[SP]I'll[SP]prove[SP]it.[1205][001E][SP]Hey...[1205][001E][SP]Are[SP]you\nscared[SP]or[SP]something...?",
