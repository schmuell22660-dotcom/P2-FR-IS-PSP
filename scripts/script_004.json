    "data_size": 72,
    "nom_orig": "Eikichi",
    "texte_orig": "K-Ken![SP]Shogo![SP]Takeshi!",
    "nom_fr": "Eikichi",
    "texte_fr": "K-Ken! Shogo! Takeshi!"
