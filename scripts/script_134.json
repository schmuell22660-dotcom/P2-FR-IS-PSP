    "data_size": 254,
    "nom_orig": "Ginko",
    "texte_orig": "Jun[SP]was[SP]so[SP]nice![SP]He[SP]taught[SP]me[SP]a[SP]lot[SP]about[SP]the\nmeanings[SP]of[SP]flowers[SP]and[SP]about[SP]stars![SP]Please,\n[U+1113],[SP]you[SP]have[SP]to[SP]save[SP]him!",
