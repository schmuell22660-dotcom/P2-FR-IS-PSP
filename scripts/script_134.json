    "slot_size": 208,
    "data_size": 204,
    "nom_orig": "Eikichi",
    "texte_orig": "That's[SP]right...[1205][001E][SP][U+1114][SP]tried[SP]to[SP]save\nBig[SP]Maya...[1205][001E][SP]We're[SP]to[SP]blame[SP]here![SP]You[SP]gotta\nremember!",
