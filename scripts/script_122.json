    "data_size": 212,
    "nom_orig": "Head[SP]monk",
    "texte_orig": "The[SP]sky[SP]is[SP]streaked[SP]with[SP]stars[SP]that[SP]should[SP]not\nbe[SP]falling[SP]now...[1205][001E][SP]What[SP]a[SP]terrible[SP]omen...",
