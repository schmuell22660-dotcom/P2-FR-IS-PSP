    "offset": 381464,
    "slot_size": 256,
    "data_size": 252,
    "nom_orig": "Young[SP]monk",
    "texte_orig": "We[SP]undergo[SP]strict[SP]training[SP]every[SP]day[SP]in[SP]hopes\nof[SP]one[SP]day[SP]learning[SP]Goketsuji's[SP]ultimate\nskill,[SP]the[SP]Mokujinken!",
