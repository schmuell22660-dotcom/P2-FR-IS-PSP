  {
    "id": 7,
    "offset": 380332,
    "slot_size": 158,
    "data_size": 154,
    "nom_orig": "Yukino",
    "texte_orig": "Sorry[SP]I[SP]lost[SP]my[SP]cool,[SP][U+1113]...[1205][001E]\nShunsuke-san...[1205][001E][SP]Please[SP]be[SP]okay...",
    "nom_fr": "Yukino",
