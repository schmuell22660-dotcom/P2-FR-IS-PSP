  {
    "id": 4,
    "offset": 379592,
    "slot_size": 214,
    "data_size": 210,
    "nom_orig": "Eikichi",
    "texte_orig": "Though[SP]on[SP]the[SP]other[SP]hand...[SP]You[SP]have[SP]to[SP]think\nof[SP]how[SP]the[SP]people[SP]you[SP]leave[SP]behind[SP]feel,[SP]huh?",
