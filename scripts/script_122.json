  {
    "id": 10,
    "offset": 380956,
    "slot_size": 262,
    "data_size": 258,
    "nom_orig": "Head[SP]monk",
    "texte_orig": "Speak[SP]of[SP]the[SP]devil[SP]and[SP]he[SP]doth[SP]appear...[1205][001E]\nThe[SP]rumors[SP]circulating[SP]are[SP]what[SP]brought[SP]about\nthis[SP]strange[SP]phenomenon.",
