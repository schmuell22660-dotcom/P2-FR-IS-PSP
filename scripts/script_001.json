    "offset": 395460,
    "slot_size": 56,
    "data_size": 52,
    "nom_orig": "Ms.[SP]Saeko",
    "texte_orig": "I[SP]see...[1205][001E]",
    "nom_fr": "Mme Saeko",
    "texte_fr": "Ok...[1205][001E]"
