  {
    "id": 26,
    "offset": 280374,
    "slot_size": 218,
    "data_size": 214,
    "nom_orig": "Maya",
    "texte_orig": "Think[SP]positive,[SP]guys![SP]Even[SP]if[SP]it[SP]doesn't\nwork[SP]out[SP]in[SP]the[SP]end,[SP]we[SP]have[SP]to[SP]at[SP]least\ngive[SP]it[SP]a[SP]shot!",
    "nom_fr": "Maya",
    "texte_fr": "Pensez positivement ! Même si ça ne\nmarche pas, on doit au moins\nessayer !"
  },
  {
    "id": 27,
    "offset": 280592,
    "slot_size": 158,
    "data_size": 154,
    "nom_orig": "Maya",
    "texte_orig": "If[SP]I[SP]remember[SP]right,[SP]Sevens'[SP]emblem[SP]is\nbased[SP]on[SP]the[SP]Pleiades,[SP]yeah?",
    "nom_fr": "Maya",
    "texte_fr": "Si je me souviens bien, l'emblème du Seven\nest basé sur les Pléiades, non ?"
