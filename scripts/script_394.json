  {
    "id": 12,
    "offset": 277840,
    "slot_size": 50,
    "data_size": 46,
    "nom_orig": "Ginko",
    "texte_orig": "A[SP]dream...!?",
    "nom_fr": "Ginko",
    "texte_fr": "Un rêve...!?"
