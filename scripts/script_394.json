  {
    "id": 11,
    "offset": 277698,
    "slot_size": 142,
    "data_size": 138,
    "nom_orig": "Eikichi",
    "texte_orig": "I[SP]played[SP]a[SP]kid's[SP]game[SP]like[SP]that[SP]in\na[SP]dream[SP]once,[SP]but...",
