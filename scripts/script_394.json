  {
    "id": 14,
    "offset": 277994,
    "slot_size": 134,
    "data_size": 130,
    "nom_orig": "Ginko",
    "texte_orig": "No,[SP]nothing...[SP]I've[SP]never[SP]played[SP]any\ngame[SP]like[SP]that...",
