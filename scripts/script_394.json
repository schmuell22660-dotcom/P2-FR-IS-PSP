[
  {
    "id": 0,
    "offset": 275806,
    "slot_size": 78,
    "data_size": 74,
    "nom_orig": "Maya",
    "texte_orig": "Whew...[1205][0014][SP]Is[SP]everyone[SP]okay?",
    "nom_fr": "Maya",
    "texte_fr": "Ouf...[1205][0014] Tout va bien ?"
  },
  {
    "id": 1,
    "offset": 275884,
    "slot_size": 114,
    "data_size": 110,
    "nom_orig": "Maya",
    "texte_orig": "H-Hey...[SP]What's[SP]wrong!?[SP]Were[SP]you[SP]that[SP]scared?",
