    "slot_size": 198,
    "data_size": 194,
    "nom_orig": "Jun",
    "texte_orig": "I[SP]can't[SP]believe[SP]this...[1205][001E][SP]This[SP]is[SP]all[SP]my[SP]fault...[1205][001E]\nHow[SP]can[SP]I[SP]atone[SP]for[SP]this?[SP]Father...",
