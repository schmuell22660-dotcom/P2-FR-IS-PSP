  {
    "id": 17,
    "offset": 218650,
    "slot_size": 230,
    "data_size": 226,
    "nom_orig": "Eikichi",
    "texte_orig": "But[SP]when[SP]I[SP]look[SP]at[SP]Big[SP]Maya[SP]and[SP]Jun,\nI[SP]think[SP]I'm[SP]probably[SP]lucky[SP]to[SP]at[SP]least\nhave[SP]a[SP]dad[SP]like[SP]mine...",
