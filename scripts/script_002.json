  {
    "id": 16,
    "offset": 365140,
    "slot_size": 242,
    "data_size": 238,
    "nom_orig": "Ken",
    "texte_orig": "We[SP]thought[SP][U+1113]-san[SP]would[SP]be[SP]a[SP]good\nfit.[1205][001E][SP]And[SP]he's[SP]reliable,[SP]so[SP]we[SP]thought\nyou'd[SP]be[SP]happy[SP]to[SP]have[SP]him[SP]aboard...",
    "nom_fr": "Ken",
