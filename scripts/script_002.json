  {
    "id": 17,
    "offset": 365382,
    "slot_size": 200,
    "data_size": 196,
    "nom_orig": "Eikichi",
    "texte_orig": "Y-You[SP]guys...[1205][001E][SP]You[SP]knew[SP]what[SP]would\nhappen[SP]if[SP]you[SP]violated[SP]Bro[SP]Code[SP]and\nyou[SP]still...",
    "nom_fr": "Eikichi",
    "texte_fr": "L-Les gars...[1205][001E] Vous saviez ce qui arrive\nsi on brise le Code\net vous l'avez fait..."
