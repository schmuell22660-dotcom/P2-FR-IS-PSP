  {
    "id": 15,
    "offset": 364874,
    "slot_size": 266,
    "data_size": 262,
    "nom_orig": "Takeshi",
    "texte_orig": "You[SP]know[SP]how[SP]you[SP]were[SP]pumped[SP]to[SP]start[SP]a\nband,[SP]Michel-san?[SP]We[SP]were[SP]looking[SP]for\nmembers.[1205][001E][SP]You[SP]were[SP]the[SP]only[SP]one,[SP]so...",
    "nom_fr": "Takeshi",
