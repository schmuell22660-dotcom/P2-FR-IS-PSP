    "data_size": 236,
    "nom_orig": "Jun",
    "texte_orig": "Only[SP]one[SP]man[SP]knew[SP]about[SP]the[SP]In[SP]Lak'ech[SP]besides\nyou[SP]and[SP]King--Tatsuya[SP]Sudou...[1205][001E][SP]I'm[SP]Akinari\nKashihara's[SP]son!",
