    "offset": 256176,
    "slot_size": 246,
    "data_size": 242,
    "nom_orig": "Female[SP]student",
    "texte_orig": "Omigosh![SP]I[SP]heard[SP]the[SP]principal[SP]went[SP]to\nthe[SP]clock[SP]tower[SP]to[SP]lift[SP]the[SP]emblem\ncurse...[SP]Did[SP]you[SP]see[SP]him!?",
