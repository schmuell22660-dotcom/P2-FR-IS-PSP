    "data_size": 54,
    "nom_orig": "Eikichi",
    "texte_orig": "Wh-What[SP]the!?",
    "nom_fr": "Eikichi",
    "texte_fr": "Qu-Quoi !?"
  },
  {
    "id": 2,
    "offset": 252334,
    "slot_size": 100,
    "data_size": 96,
    "nom_orig": "Yukino",
    "texte_orig": "Careful,[SP]everyone![SP]It's[SP]collapsing!",
