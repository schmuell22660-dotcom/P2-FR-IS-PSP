    "offset": 240994,
    "slot_size": 124,
    "data_size": 120,
    "nom_orig": "Eikichi",
    "texte_orig": "Tons[SP]of[SP]people[SP]died![SP]And[SP]for[SP]no[SP]reason,[SP]dammit!",
    "nom_fr": "Eikichi",
    "texte_fr": "Y'a eu plein de morts! Pour aucune raison!"
