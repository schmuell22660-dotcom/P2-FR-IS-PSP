[
  {
    "id": 0,
    "offset": 239314,
    "slot_size": 164,
    "data_size": 160,
    "nom_orig": "Eikichi",
    "texte_orig": "Hey,[SP][U+1113].[SP]Is[SP]that[SP]lady[SP]checking[SP]me[SP]out?\nWould[SP]you[SP]go[SP]find[SP]out[SP]for[SP]me?",
    "nom_fr": "Eikichi",
