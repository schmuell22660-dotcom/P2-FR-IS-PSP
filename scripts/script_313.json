  {
    "id": 7,
    "offset": 241118,
    "slot_size": 288,
    "data_size": 284,
    "nom_orig": "Eikichi",
    "texte_orig": "We[SP]live[SP]in[SP]the[SP]same[SP]world,[SP]the[SP]same[SP]city,[SP]but\neveryone's[SP]perception[SP]of[SP]it[SP]is[SP]different...[1205][U+000F]\nStill,[SP]that[SP]teacher's[SP]something[SP]else.",
